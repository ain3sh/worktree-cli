          return 1
        fi
        if [ ! -d "$path" ]; then
          log_error "Directory not found: $path"
          return 1
        fi
        # Try cursor-agent first, then fallback to cursor CLI commands
        if command -v cursor-agent >/dev/null 2>&1; then
          (cd "$path" && cursor-agent "$@")
        elif command -v cursor >/dev/null 2>&1; then
