  local ai_tool="$1"
  case "$ai_tool" in
    aider)
      ai_can_start() {
        command -v aider >/dev/null 2>&1
      }
      ai_start() {
        local path="$1"
        shift
        if ! ai_can_start; then
          log_error "Aider not found. Install with: pip install aider-chat"
          log_info "See https://aider.chat for more information"
          return 1
        fi
        if [ ! -d "$path" ]; then
          log_error "Directory not found: $path"
          return 1
        fi
        # Change to the directory and run aider with any additional arguments
        (cd "$path" && aider "$@")
      }
      return 0
      ;;
    claude)
      find_claude_executable() {
        local cmd
        # Check common installation paths first
        if [ -x "$HOME/.claude/local/claude" ]; then
          echo "$HOME/.claude/local/claude"
          return 0
        fi
        # Try to find executable using type -P (Bash/Zsh)
        for cmd in claude claude-code; do
          local exe_path
          exe_path="$(type -P "$cmd" 2>/dev/null)" && [ -n "$exe_path" ] && {
            echo "$exe_path"
            return 0
          }
        done
        # Fallback: use type -t to check if it's an executable file
        for cmd in claude claude-code; do
          if [ "$(type -t "$cmd" 2>/dev/null)" = "file" ]; then
            command -v "$cmd"
            return 0
          fi
        done
        return 1
      }
      ai_can_start() {
        find_claude_executable >/dev/null 2>&1
      }
      ai_start() {
        local path="$1"
        shift
        local claude_cmd
        claude_cmd="$(find_claude_executable)"
        if [ -z "$claude_cmd" ]; then
          log_error "Claude Code not found. Install from https://claude.com/claude-code"
          log_info "The CLI is called 'claude' (or 'claude-code' in older versions)"
          return 1
        fi
        if [ ! -d "$path" ]; then
          log_error "Directory not found: $path"
          return 1
        fi
        (cd "$path" && "$claude_cmd" "$@")
      }
      return 0
      ;;
    codex)
      ai_can_start() {
        command -v codex >/dev/null 2>&1
      }
      ai_start() {
        local path="$1"
        shift
        if ! ai_can_start; then
          log_error "Codex CLI not found. Install with: npm install -g @openai/codex"
