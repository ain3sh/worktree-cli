        fi
        if [ ! -d "$path" ]; then
          log_error "Directory not found: $path"
          return 1
        fi
        # Change to the directory and run cn with any additional arguments
        (cd "$path" && cn "$@")
      }
      return 0
      ;;
    cursor)
      ai_can_start() {
